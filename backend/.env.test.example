# Copy to .env.test and fill in your test database URL
# Use a SEPARATE database from production — tests wipe all data on every run

TEST_DATABASE_URL=postgresql://user:pass@host/eventnest_test?sslmode=require
JWT_SECRET=test-secret-minimum-32-characters-long
JWT_REFRESH_SECRET=test-refresh-secret-string
PORT=8081
NODE_ENV=test
CLIENT_URL=http://localhost:3000
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=test@example.com
SMTP_PASS=testpassword
SMTP_FROM=EventNest Test <test@example.com>
